# Copy to .env and fill in values. Never commit .env.

# Active LLM provider: openai | gemini | anthropic | kimi
LINKROWTH_PROVIDER=openai

# Provider API keys — only the active provider's key is required
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=

# Optional default model overrides per provider
LINKROWTH_OPENAI_MODEL=gpt-4o-mini
LINKROWTH_GEMINI_MODEL=gemini-2.5-flash
LINKROWTH_ANTHROPIC_MODEL=claude-sonnet-4-6
LINKROWTH_KIMI_MODEL=moonshot-v1-8k
